<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.biz.mapper.AiEventMapper">

    <resultMap type="AiEvent" id="AiEventResult">
            <result property="eventId" column="event_id"/>
            <result property="cameraId" column="camera_id"/>
            <result property="cameraName" column="camera_name"/>
            <result property="slotId" column="slot_id"/>
            <result property="slotCode" column="slot_code"/>
            <result property="oldStatus" column="old_status"/>
            <result property="newStatus" column="new_status"/>
            <result property="confidence" column="confidence"/>
            <result property="eventTime" column="event_time"/>
            <result property="framePath" column="frame_path"/>
            <result property="delFlag" column="del_flag"/>
            <result property="createBy" column="create_by"/>
            <result property="createTime" column="create_time"/>
            <result property="updateBy" column="update_by"/>
            <result property="updateTime" column="update_time"/>
            <result property="remark" column="remark"/>
            <result property="imageUrl" column="image_url"/>
    </resultMap>
</mapper>