# =============================================
# 社区车位占用检测系统 - 本地环境变量模板
# =============================================
# Copy this file to .env, then fill local MySQL/Redis credentials.

# ===== MySQL =====
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=smart_parking
MYSQL_USER=Server
MYSQL_PASSWORD=change_me_mysql_password

# ===== Redis =====
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=1

# ===== Backend secrets =====
TOKEN_SECRET=change_me_token_secret
OPENAI_API_KEY=

# Druid Console
DRUID_USERNAME=admin
DRUID_PASSWORD=change_me_druid

# ===== AI inference =====
AI_FASTAPI_URL=http://127.0.0.1:8000
BACKEND_BASE_URL=http://127.0.0.1:8087
BACKEND_PARKING_API=/biz/parking/detect
BACKEND_PUSH_TIMEOUT_SECONDS=3.0
BACKEND_PUSH_MAX_RETRIES=3
BACKEND_PUSH_BACKOFF_BASE=0.5
SLOT_CODE_FORMAT={parking_lot_id}-{slot_id}

# ===== Frontend =====
VITE_API_BASE_URL=http://127.0.0.1:8087
VITE_DEV_SERVER_PORT=5173

# ===== Backend =====
SERVER_PORT=8087

# ===== Timezone =====
TZ=Asia/Shanghai

# ===== CORS =====
CORS_ALLOWED_ORIGINS=http://localhost:5173
CORS_ALLOW_CREDENTIALS=true
