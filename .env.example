# =============================================
# Smart Parking - Docker environment template
# =============================================
# Copy this file to .env, then change every password before exposing services.

# ===== MySQL =====
MYSQL_ROOT_PASSWORD=change_me_mysql_root
MYSQL_USER=smart_parking
MYSQL_PASSWORD=change_me_mysql_app
MYSQL_DATABASE=smart_parking
MYSQL_HOST_PORT=3307
MYSQL_IMAGE=mysql:8.4

# ===== Redis =====
REDIS_PASSWORD=change_me_redis
REDIS_DATABASE=0
REDIS_HOST_PORT=6379
REDIS_IMAGE=redis:7.4-alpine

# ===== Spring Boot =====
SPRING_PROFILES_ACTIVE=devmy,docker

# Druid Console
DRUID_LOGIN_USERNAME=admin
DRUID_LOGIN_PASSWORD=change_me_druid

# ===== AI inference =====
AI_HOST_PORT=8000
RUOYI_BASE_URL=http://ruoyi-server:8080
RUOYI_PARKING_API=/biz/parking/detect
RUOYI_PUSH_TIMEOUT_SECONDS=3.0
SLOT_CODE_FORMAT={parking_lot_id}-{slot_id}

# ===== Frontend =====
# Use 8088 on Windows when port 80 is occupied by IIS, Nginx, or another Docker app.
UI_HOST_PORT=8088
VITE_API_BASE_URL=/prod-api

# ===== Backend =====
RUOYI_HOST_PORT=8087

# ===== AI gateway (optional profile: gateway) =====
NEW_API_HOST_PORT=3000

# ===== Timezone =====
TZ=Asia/Shanghai

# ===== Prometheus / Grafana (prod compose only) =====
PROMETHEUS_HOST_PORT=9090
PROMETHEUS_RETENTION_TIME=15d
PROMETHEUS_STORAGE_SIZE=10GB
GRAFANA_HOST_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana
GRAFANA_ROOT_URL=http://localhost:3001
GRAFANA_DOMAIN=localhost

# ===== CORS =====
CORS_ALLOWED_ORIGINS=http://localhost:8088,http://localhost:5173
CORS_ALLOW_CREDENTIALS=true
