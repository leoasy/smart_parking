# =========================================
# Parking AI Service — Dockerfile.ai
# Ultralytics YOLO + FastAPI + PyTorch
# =========================================

# Build with: docker build --dangerously-skip-permissions -t parking-ai -f Dockerfile.ai .

# 使用 Python 3.11 基础镜像
FROM python:3.11-slim

# 容器内部构建，不继承宿主权限
USER root

WORKDIR /app

# 安装系统依赖（OpenCV/glib 兼容 + curl 健康检查）
RUN apt-get update && apt-get install -y --no-install-recommends \
        libgl1 \
        libglib2.0-0 \
        libsm6 \
        libxext6 \
        libxrender1 \
        libgomp1 \
        curl \
    && rm -rf /var/lib/apt/lists/*

# 时区配置
ENV TZ=Asia/Shanghai
RUN ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && echo $TZ > /etc/timezone

# 预装 Python 依赖（使用清华镜像加速）
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt \
    -i https://pypi.tuna.tsinghua.edu.cn/simple

# 拷贝应用代码
COPY . .

# 模型通过 volume 挂载，避免镜像过大
VOLUME ["/app/model"]

# 监听端口
EXPOSE 8000

# 健康检查
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1

# 生产模式启动（关闭 reload，使用多 worker）
CMD ["uvicorn", "main_api:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "2"]
